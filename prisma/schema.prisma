// AceitoFiado — schema do banco de dados
// Crédito mercantil escritural com trava de recebíveis,
// pra cadeia afroempreendedora.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────── Enums ───────────────────────

enum Role {
  ENTREPRENEUR
  SUPPLIER
  ADMIN
}

enum ChannelType {
  PIX
  SHOPEE
  MERCADO_LIVRE
  INSTAGRAM
  FEIRA
  MAQUININHA
  OUTRO
}

enum ChannelStatus {
  ACTIVE
  INACTIVE
}

enum SupplierCategory {
  TEXTIL
  COSMETICOS
  ALIMENTOS
  BEBIDAS
  PAPELARIA
  ACESSORIOS
  CALCADOS
  BAZAR
  OUTROS
}

enum OrderStatus {
  AWAITING_SUPPLIER
  SUPPLIER_CONFIRMED
  FUNDED
  ACTIVE
  REPAID
  OVERDUE
  CANCELLED
}

enum DuplicataStatus {
  ISSUED
  REGISTERED
  LIQUIDATED
  PROTESTED
}

enum CheckoutSource {
  QR_PRESENCIAL
  API_MARKETPLACE
}

enum CheckoutStatus {
  PENDING
  CONFIRMED
  EXPIRED
  CANCELLED
}

// ─────────────────────── Modelos ─────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  entrepreneur EntrepreneurProfile?
  supplier     SupplierProfile?
  sessions     Session[]

  @@index([email])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model EntrepreneurProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cnpj                String   @unique
  businessName        String
  phone               String
  addressCep          String
  addressCity         String
  addressState        String
  addressNeighborhood String
  avatarUrl           String?
  businessSince       DateTime
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  channels         Channel[]
  scoreSnapshots   ScoreSnapshot[]
  orders           Order[]
  pixTransactions  PixTransaction[]
  checkoutSessions CheckoutSession[]

  @@index([cnpj])
}

model SupplierProfile {
  id                  String           @id @default(cuid())
  userId              String           @unique
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  cnpj                String           @unique
  businessName        String
  phone               String
  addressCep          String
  addressCity         String
  addressState        String
  addressNeighborhood String
  category            SupplierCategory
  description         String
  logoUrl             String?
  pixKey              String
  defaultDiscountBps  Int              @default(300)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  latitude    Float?
  longitude   Float?
  serviceTags String[]  @default([])

  products         Product[]
  orders           Order[]
  checkoutSessions CheckoutSession[]

  @@index([cnpj])
  @@index([category])
}

model Channel {
  id                  String              @id @default(cuid())
  entrepreneurId      String
  entrepreneur        EntrepreneurProfile @relation(fields: [entrepreneurId], references: [id], onDelete: Cascade)
  type                ChannelType
  label               String
  monthlyRevenueCents BigInt              @default(0)
  status              ChannelStatus       @default(ACTIVE)
  connectedAt         DateTime            @default(now())

  pixTransactions PixTransaction[]

  @@index([entrepreneurId])
}

model ScoreSnapshot {
  id                 String              @id @default(cuid())
  entrepreneurId     String
  entrepreneur       EntrepreneurProfile @relation(fields: [entrepreneurId], references: [id], onDelete: Cascade)
  score              Float
  approvedLimitCents BigInt
  inputsJson         Json
  rationale          String
  calculatedAt       DateTime            @default(now())

  @@index([entrepreneurId, calculatedAt])
}

model Product {
  id          String          @id @default(cuid())
  supplierId  String
  supplier    SupplierProfile @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  sku         String
  name        String
  description String
  priceCents  BigInt
  unit        String
  imageUrl    String?
  stock       Int             @default(0)
  minQuantity Int             @default(1)
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())

  orderItems OrderItem[]

  @@unique([supplierId, sku])
  @@index([supplierId])
  @@index([active])
}

model Order {
  id                   String              @id @default(cuid())
  entrepreneurId       String
  entrepreneur         EntrepreneurProfile @relation(fields: [entrepreneurId], references: [id], onDelete: Cascade)
  supplierId           String
  supplier             SupplierProfile     @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  status               OrderStatus         @default(AWAITING_SUPPLIER)
  subtotalCents        BigInt
  supplierDiscountBps  Int
  supplierReceiveCents BigInt
  customerInterestBps  Int
  customerPayCents     BigInt
  termDays             Int
  platformFeeCents     BigInt
  captureRateBps       Int                 @default(3000)

  requestedAt DateTime  @default(now())
  confirmedAt DateTime?
  fundedAt    DateTime?
  dueDate     DateTime?
  repaidAt    DateTime?

  items           OrderItem[]
  duplicata       Duplicata?
  receivables     Receivable[]
  checkoutSession CheckoutSession?

  @@index([entrepreneurId, status])
  @@index([supplierId, status])
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String
  product        Product @relation(fields: [productId], references: [id])
  quantity       Int
  unitPriceCents BigInt
  totalCents     BigInt

  @@index([orderId])
}

model Duplicata {
  id               String          @id @default(cuid())
  orderId          String          @unique
  order            Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  numero           String          @unique
  valorCents       BigInt
  vencimento       DateTime
  sacadoCnpj       String
  sacadoNome       String
  sacadorCnpj      String
  sacadorNome      String
  registradoraCode String          @default("CERC")
  registradoraTxid String?
  status           DuplicataStatus @default(ISSUED)
  issuedAt         DateTime        @default(now())
}

model PixTransaction {
  id                  String              @id @default(cuid())
  entrepreneurId      String
  entrepreneur        EntrepreneurProfile @relation(fields: [entrepreneurId], references: [id], onDelete: Cascade)
  channelId           String?
  channel             Channel?            @relation(fields: [channelId], references: [id])
  valueCents          BigInt
  payerName           String
  payerDocument       String
  txid                String              @unique
  receivedAt          DateTime
  captured            Boolean             @default(false)
  capturedAmountCents BigInt              @default(0)
  createdAt           DateTime            @default(now())

  receivable Receivable?

  @@index([entrepreneurId, receivedAt])
}

model Receivable {
  id                  String         @id @default(cuid())
  orderId             String
  order               Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  pixTransactionId    String         @unique
  pixTransaction      PixTransaction @relation(fields: [pixTransactionId], references: [id], onDelete: Cascade)
  amountCapturedCents BigInt
  capturedAt          DateTime       @default(now())

  @@index([orderId])
}

model CheckoutSession {
  id             String          @id @default(cuid())
  code           String          @unique
  supplierId     String
  entrepreneurId String?
  amount         BigInt
  items          Json
  prazo          Int
  source         CheckoutSource  @default(QR_PRESENCIAL)
  status         CheckoutStatus  @default(PENDING)
  expiresAt      DateTime
  confirmedAt    DateTime?
  orderId        String?         @unique

  // API marketplace
  marketplaceId String?
  successUrl    String?
  webhookUrl    String?
  cancelUrl     String?

  supplier     SupplierProfile      @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  entrepreneur EntrepreneurProfile? @relation(fields: [entrepreneurId], references: [id])
  order        Order?               @relation(fields: [orderId], references: [id])

  createdAt DateTime @default(now())

  @@index([code])
  @@index([supplierId, status])
}
